{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist-test",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "db://*": ["game/assets/scripts/*"]
    }
  },
  "include": [
    "game/assets/scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
